# WhatsApp Gateway Configuration
# Base URL of the WhatsApp Gateway API
WAGA_BASE_URL=http://localhost:3000/api/v1

# Pre-authenticated JWT token for the WhatsApp account
# Obtain this by registering a phone number against the gateway
WAGA_JWT_TOKEN=your_jwt_token_here

# Application Environment
# Valid values: dev, prod
APP_ENV=dev

# Logging Level
# Valid values: debug, info, warn, error
LOG_LEVEL=info

# MCP Transport Type
# Valid values: stdio, http
# stdio: Runs as stdio MCP server (for Claude Desktop, Cursor, Claude Code)
# http: Runs HTTP+SSE MCP server on MCP_PORT
MCP_TRANSPORT=stdio

# HTTP+SSE Server Port (only used when MCP_TRANSPORT=http)
MCP_PORT=8080

# Basic Auth Credentials (required only when APP_ENV=prod and MCP_TRANSPORT=http)
MCP_BASIC_AUTH_USER=admin
MCP_BASIC_AUTH_PASSWORD=your_secure_password_here
